{
  "name": "ops-app",
  "version": "1.0.0",
  "description": "Operations management system for School Uniform Solutions",
  "author": "School Uniform Solutions",
  "build": {
    "appId": "com.schooluniformsolutions.ops",
    "productName": "School Uniform Ops",
    "win": {
      "target": "portable",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "files": [
      "out/**/*",
      "main.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:desktop": "next build && electron-builder",
    "env:clone": "node scripts/switch-woo-env.js clone",
    "env:real": "node scripts/switch-woo-env.js real",
    "seed:school-ops": "npx ts-node scripts/set-school-ops-password.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/openai": "^3.0.19",
    "@ai-sdk/react": "^3.0.52",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@supabase/supabase-js": "^2.93.1",
    "@types/uuid": "^10.0.0",
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "ai": "^6.0.50",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "electron-serve": "^3.0.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "serve": "^14.2.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.8",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/bcryptjs": "^2.4.6",
    "@types/react-dom": "^19",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
