# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WooCommerce REST API (required for Orders sync, order details, product images)
# Get keys from: WooCommerce → Settings → Advanced → REST API → Add key
WOO_URL=https://your-woocommerce-site.com
WOO_CONSUMER_KEY=ck_xxxxxxxxxxxx
WOO_CONSUMER_SECRET=cs_xxxxxxxxxxxx

# Anthropic (Claude) – for "Parse with AI" in bulk orders and other AI features
# Get key from console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: WordPress (scripts / Divi updates; separate from WooCommerce API)
# WORDPRESS_URL=
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=
